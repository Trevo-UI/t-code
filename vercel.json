{
  "version": 2,
  "builds": [
    { "src": "src/api/server.cjs", "use": "@vercel/node" },
    { "src": "vite", "use": "@vercel/node" },
    { "src": "dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/api/server.cjs" },
    { "src": "/(.*)", "dest": "/vite/$1" }
  ]
}
